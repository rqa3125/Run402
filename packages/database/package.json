{
  "name": "@run402/database",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle ORM schema, client and migrations for Run402 (PostgreSQL).",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@run402/env": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@run402/config": "workspace:*",
    "@types/node": "^22.20.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}

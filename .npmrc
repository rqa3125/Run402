# Ensure hoisting patterns that keep tooling (eslint, prettier, tailwind) resolvable
# from every workspace while preserving strict dependency isolation.
auto-install-peers=true
strict-peer-dependencies=false
# Better Auth, Drizzle and Next need their transitive deps hoisted for some plugins
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*tailwind*
public-hoist-pattern[]=*postcss*

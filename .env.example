# ---------------------------------------------------------------------------
# Run402 — environment variables
# Copy to `.env` at the repo root. Every variable is validated at boot by
# @run402/env (Zod). Missing/invalid values fail fast with a readable error.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/run402

# Authentication (Clerk) — written to apps/dashboard/.env.local by `clerk init`
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Dashboard app (client-visible)
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Email (Resend) — not wired to business logic yet
RESEND_API_KEY=

# Payments (Stripe) — placeholder only, no logic implemented yet
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENTS_PROVIDER=mock

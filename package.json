{
  "name": "run402",
  "version": "0.0.0",
  "private": true,
  "description": "Run402 — the easiest way to monetize APIs. Production monorepo.",
  "author": "Manoj",
  "license": "MIT",
  "homepage": "https://github.com/rqa3125/Run402",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rqa3125/Run402.git"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "cli": "pnpm --filter @run402/cli exec tsx src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:studio": "pnpm --filter @run402/database db:studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@run402/config": "workspace:*",
    "@types/node": "^22.20.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
